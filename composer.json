{
    "name": "migel/ventaspos",
    "description": "Legacy POS modernized for PHP 8.5 with gradual compatibility bridge.",
    "type": "project",
    "require": {
        "php": "^8.3",
        "symfony/polyfill-iconv": "^1.33",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.89",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.0",
        "rector/rector": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "VentasPos\\": "app/"
        },
        "files": [
            "app/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "VentasPos\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
