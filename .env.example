APP_NAME="ventaspos"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/ventaspos
APP_ASSET_URL=http://localhost/ventaspos/public/assets
FRONTEND_URL=http://localhost:4200
LEGACY_BRIDGE_SECRET=ventaspos-legacy-bridge-local
APP_TIMEZONE=America/Guayaquil

SESSION_NAME=ventaspos_session
SESSION_LIFETIME=7200

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=icontpos
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

UPLOADS_DISK_PATH=storage/uploads/fotoproducto
UPLOADS_PUBLIC_PATH=fotoproducto
UPLOADS_PUBLIC_DISK=public/assets/fotoproducto
UPLOADS_MAX_SIZE=5242880
