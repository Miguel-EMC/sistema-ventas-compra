{
  "name": "ventaspos-ui",
  "private": true,
  "scripts": {
    "start:web": "npm --prefix apps/web start",
    "build:web": "npm --prefix apps/web run build",
    "test:web": "npm --prefix apps/web run test",
    "dev:api": "composer --working-dir=apps/api run-script dev",
    "test:api": "composer --working-dir=apps/api run-script test",
    "build:css": "sass --no-source-map resources/scss/app.scss public/assets/css/app.css",
    "watch:css": "sass --watch resources/scss/app.scss:public/assets/css/app.css"
  },
  "devDependencies": {
    "sass": "^1.93.0"
  }
}
